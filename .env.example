# Wazuh connection
WAZUH_HOST=your.wazuh.host
WAZUH_USER=changeme
WAZUH_PASS=yourpassword

# SOCops settings
SOCOPS_PORT=8081
POLL_INTERVAL=60
INITIAL_WINDOW=now-24h

# AI analysis (optional — set one)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku  # any model slug from openrouter.ai/models

# Threat intel enrichment (optional)
ABUSEIPDB_KEY=
OTX_KEY=

# Notifications (optional)
NOTIFY_WEBHOOK=
NOTIFY_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_LEVEL=12
