# Wazuh connection
WAZUH_HOST=your.wazuh.host
WAZUH_USER=changeme
WAZUH_PASS=yourpassword

# SOCops settings
SOCOPS_PORT=8081
POLL_INTERVAL=60
INITIAL_WINDOW=now-24h

# AI analysis — dispatch order: Ollama → OpenRouter → rule-based stub
# Option 1: Local Ollama via AnythingLLM Desktop (preferred — alert data stays on your network)
#           https://anythingllm.com — bundles Ollama, no extra setup needed
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b            # pull first: curl http://127.0.0.1:11434/api/pull -d '{"name":"qwen2.5:3b"}'

# Option 2: OpenRouter (free models available)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku  # any model slug from openrouter.ai/models

# Option 3: Anthropic Claude (cloud)
ANTHROPIC_API_KEY=

# Threat intel enrichment (optional)
ABUSEIPDB_KEY=
OTX_KEY=

# Notifications (optional)
NOTIFY_WEBHOOK=
NOTIFY_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_LEVEL=12
